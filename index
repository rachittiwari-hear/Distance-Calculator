<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pincode Centre Mapping Platform</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f0; color: #1a1a1a; min-height: 100vh; }

  .header { background: #fff; border-bottom: 1px solid #e5e5e0; padding: 16px 32px; display: flex; align-items: center; gap: 16px; }
  .header-logo { width: 36px; height: 36px; background: #1a6ef5; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .header-logo svg { width: 20px; height: 20px; fill: none; stroke: #fff; stroke-width: 2; }
  .header h1 { font-size: 17px; font-weight: 600; }
  .header p { font-size: 13px; color: #666; margin-top: 1px; }

  .main { max-width: 1400px; margin: 0 auto; padding: 28px 24px; }

  .config-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
  .card { background: #fff; border: 1px solid #e5e5e0; border-radius: 10px; padding: 20px; }
  .card h2 { font-size: 13px; font-weight: 600; color: #444; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 14px; }

  .api-input-row { display: flex; gap: 10px; align-items: center; }
  .api-input { flex: 1; padding: 9px 12px; border: 1px solid #ddd; border-radius: 7px; font-size: 13px; font-family: monospace; }
  .api-input:focus { outline: none; border-color: #1a6ef5; box-shadow: 0 0 0 3px rgba(26,110,245,0.1); }
  .api-status { font-size: 12px; margin-top: 6px; }
  .api-status.ok { color: #2a9d5c; }
  .api-status.err { color: #e05050; }

  .range-row { display: flex; align-items: center; gap: 12px; }
  .range-row input[type=range] { flex: 1; accent-color: #1a6ef5; }
  .range-val { font-size: 14px; font-weight: 600; color: #1a6ef5; min-width: 60px; }
  .range-hint { font-size: 12px; color: #888; margin-top: 6px; }

  .upload-zone { border: 2px dashed #d0d0cc; border-radius: 10px; padding: 32px 20px; text-align: center; cursor: pointer; transition: all 0.2s; background: #fafaf8; }
  .upload-zone:hover, .upload-zone.drag { border-color: #1a6ef5; background: #f0f5ff; }
  .upload-zone svg { width: 40px; height: 40px; stroke: #aaa; fill: none; stroke-width: 1.5; margin-bottom: 10px; }
  .upload-zone p { font-size: 14px; color: #555; }
  .upload-zone span { font-size: 12px; color: #999; display: block; margin-top: 4px; }
  #file-input { display: none; }

  .template-row { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .btn { padding: 8px 16px; border-radius: 7px; border: 1px solid #ddd; background: #fff; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: all 0.15s; font-weight: 500; }
  .btn:hover { background: #f5f5f0; border-color: #bbb; }
  .btn-primary { background: #1a6ef5; color: #fff; border-color: #1a6ef5; }
  .btn-primary:hover { background: #1560d8; }
  .btn-primary:disabled { background: #99b8f7; border-color: #99b8f7; cursor: not-allowed; }
  .btn-green { background: #2a9d5c; color: #fff; border-color: #2a9d5c; }
  .btn-green:hover { background: #228a4f; }
  .btn-danger { background: #e05050; color: #fff; border-color: #e05050; }
  .btn-danger:hover { background: #c43c3c; }

  .preview-section { margin-top: 20px; }
  .preview-section h2 { font-size: 13px; font-weight: 600; color: #444; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 12px; }

  .table-wrap { overflow-x: auto; border: 1px solid #e5e5e0; border-radius: 10px; background: #fff; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th { background: #f8f8f5; font-weight: 600; font-size: 12px; color: #555; text-transform: uppercase; letter-spacing: 0.04em; padding: 10px 14px; border-bottom: 1px solid #e5e5e0; white-space: nowrap; text-align: left; }
  tbody td { padding: 9px 14px; border-bottom: 1px solid #f0f0ec; vertical-align: top; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: #fafaf8; }
  .col-pin { font-family: monospace; font-weight: 600; }
  .col-result { max-width: 280px; }
  .centres-list { display: flex; flex-direction: column; gap: 2px; }
  .centre-chip { font-size: 11px; background: #eef4ff; color: #1a6ef5; border-radius: 4px; padding: 2px 7px; display: inline-block; margin: 1px 2px 1px 0; }
  .dist-chip { font-size: 11px; background: #f0faf5; color: #2a9d5c; border-radius: 4px; padding: 2px 7px; display: inline-block; margin: 1px 2px 1px 0; }
  .status-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; padding: 3px 9px; border-radius: 20px; font-weight: 500; }
  .badge-pending { background: #f5f0e0; color: #8a6000; }
  .badge-processing { background: #e8f0ff; color: #1a4ea8; }
  .badge-done { background: #e0f5ea; color: #1a7a42; }
  .badge-error { background: #fde8e8; color: #a02020; }

  .progress-bar-wrap { height: 6px; background: #e5e5e0; border-radius: 3px; overflow: hidden; margin: 8px 0; }
  .progress-bar { height: 100%; background: #1a6ef5; border-radius: 3px; transition: width 0.3s ease; width: 0%; }

  .action-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin: 16px 0; }
  .count-info { font-size: 13px; color: #666; margin-left: auto; }

  .format-hint { background: #f8f8f5; border: 1px solid #e5e5e0; border-radius: 8px; padding: 14px 18px; margin-bottom: 20px; }
  .format-hint h3 { font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 8px; }
  .format-hint code { font-family: monospace; font-size: 12px; background: #eee; padding: 2px 6px; border-radius: 3px; }
  .format-hint p { font-size: 13px; color: #555; margin-bottom: 4px; }

  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .log-panel { background: #1a1a1a; border-radius: 10px; padding: 14px 18px; max-height: 160px; overflow-y: auto; font-family: monospace; font-size: 12px; color: #ccc; margin-top: 12px; }
  .log-line { margin: 1px 0; }
  .log-ok { color: #5dd88a; }
  .log-err { color: #f08080; }
  .log-info { color: #80c8f0; }

  .empty-state { text-align: center; padding: 60px 20px; color: #aaa; }
  .empty-state svg { width: 52px; height: 52px; stroke: #ccc; fill: none; stroke-width: 1.3; margin-bottom: 14px; }
  .empty-state p { font-size: 15px; }
  .empty-state span { font-size: 13px; display: block; margin-top: 4px; color: #bbb; }

  .tabs { display: flex; gap: 0; border-bottom: 1px solid #e5e5e0; margin-bottom: 20px; }
  .tab { padding: 10px 20px; font-size: 13px; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; color: #888; transition: all 0.15s; }
  .tab.active { border-bottom-color: #1a6ef5; color: #1a6ef5; }

  .results-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  .stat-card { background: #fff; border: 1px solid #e5e5e0; border-radius: 8px; padding: 14px 16px; }
  .stat-val { font-size: 22px; font-weight: 600; color: #1a1a1a; }
  .stat-label { font-size: 12px; color: #888; margin-top: 2px; }
</style>
</head>
<body>

<div class="header">
  <div class="header-logo">
    <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
  </div>
  <div>
    <h1>Pincode Centre Mapping</h1>
    <p>Find hearing centres within range of each pincode using Google Maps API</p>
  </div>
</div>

<div class="main">

  <div class="config-row">
    <div class="card">
      <h2>Google Maps API Key</h2>
      <div class="api-input-row">
        <input type="password" class="api-input" id="api-key" placeholder="AIzaSy..." value="AIzaSyBOOQQ3-EBarFxS0">
        <button class="btn" onclick="testApiKey()">Test</button>
      </div>
      <div class="api-status" id="api-status"></div>
      <p style="font-size:12px;color:#999;margin-top:8px;">Requires Distance Matrix API enabled on your key</p>
    </div>
    <div class="card">
      <h2>Search Radius</h2>
      <div class="range-row">
        <input type="range" min="5" max="100" value="32" step="1" id="radius-range" oninput="document.getElementById('radius-val').textContent=this.value+' km'">
        <span class="range-val" id="radius-val">32 km</span>
      </div>
      <p class="range-hint">Centres within this distance from each pincode will be included in results</p>
    </div>
  </div>

  <div class="format-hint">
    <h3>CSV Format Required</h3>
    <p>Your CSV must have exactly these 6 columns (with or without a header row):</p>
    <p style="margin-top:6px;font-family:monospace;font-size:13px;background:#fff;border:1px solid #ddd;border-radius:6px;padding:10px 14px;">
      <strong>Centre Name</strong> , <strong>Centre Lat</strong> , <strong>Centre Long</strong> , <strong>Pincode</strong> , <strong>Pincode Lat</strong> , <strong>Pincode Long</strong>
    </p>
    <p style="margin-top:6px;">Example: <code>Aanvii Hearing - Ahmedabad</code>, <code>23.0397</code>, <code>72.5150</code>, <code>302034</code>, <code>26.8574</code>, <code>75.7873</code></p>
  </div>

  <div class="card" style="margin-bottom:20px;">
    <h2>Upload Data</h2>
    <div class="upload-zone" id="drop-zone" onclick="document.getElementById('file-input').click()" ondragover="event.preventDefault();this.classList.add('drag')" ondragleave="this.classList.remove('drag')" ondrop="handleDrop(event)">
      <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      <p>Drop your CSV file here or click to browse</p>
      <span>Supports .csv files · Centre Name, Lat, Long, Pincode, Lat, Long</span>
    </div>
    <input type="file" id="file-input" accept=".csv" onchange="loadFile(this.files[0])">
    <div class="template-row">
      <button class="btn" onclick="downloadTemplate()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Template CSV
      </button>
      <button class="btn" onclick="loadSampleData()">Load Sample Data</button>
    </div>
  </div>

  <div id="data-section" style="display:none;">
    <div class="tabs">
      <div class="tab active" onclick="switchTab('input')" id="tab-input">Input Data</div>
      <div class="tab" onclick="switchTab('results')" id="tab-results">Results</div>
    </div>

    <div id="tab-content-input">
      <div class="action-row">
        <button class="btn btn-primary" id="run-btn" onclick="runMapping()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Run Mapping
        </button>
        <button class="btn btn-danger" onclick="clearData()">Clear</button>
        <span class="count-info" id="count-info"></span>
      </div>
      <div id="progress-wrap" style="display:none;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
          <span style="font-size:13px;color:#555;" id="progress-label">Processing...</span>
          <span style="font-size:13px;font-weight:600;color:#1a6ef5;" id="progress-pct">0%</span>
        </div>
        <div class="progress-bar-wrap"><div class="progress-bar" id="progress-bar"></div></div>
        <div class="log-panel" id="log-panel"></div>
      </div>
      <div class="preview-section">
        <h2>Input Preview</h2>
        <div class="table-wrap" id="input-table-wrap">
          <div class="empty-state">
            <p>No data loaded</p>
          </div>
        </div>
      </div>
    </div>

    <div id="tab-content-results" style="display:none;">
      <div class="results-stats" id="results-stats" style="display:none;"></div>
      <div class="action-row">
        <button class="btn btn-green" id="download-btn" onclick="downloadResults()" style="display:none;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Results CSV
        </button>
      </div>
      <div class="table-wrap" id="results-table-wrap">
        <div class="empty-state">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <p>No results yet</p>
          <span>Run the mapping to see results here</span>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
let csvData = [];
let resultsData = [];
let isRunning = false;

const BATCH_SIZE = 10;
const DELAY_MS = 200;

function log(msg, type='info') {
  const panel = document.getElementById('log-panel');
  const d = document.createElement('div');
  d.className = 'log-line log-' + type;
  d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;
  panel.appendChild(d);
  panel.scrollTop = panel.scrollHeight;
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function getApiKey() { return document.getElementById('api-key').value.trim(); }
function getRadius() { return parseInt(document.getElementById('radius-range').value); }

async function testApiKey() {
  const key = getApiKey();
  if (!key) { setApiStatus('No API key entered', false); return; }
  setApiStatus('Testing...', null);
  try {
    const url = `https://maps.googleapis.com/maps/api/distancematrix/json?origins=28.6139,77.2090&destinations=19.0760,72.8777&key=${key}`;
    const r = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`);
    const d = await r.json();
    const parsed = JSON.parse(d.contents);
    if (parsed.status === 'OK') setApiStatus('API key valid ✓', true);
    else setApiStatus('Error: ' + parsed.error_message || parsed.status, false);
  } catch(e) {
    setApiStatus('Could not verify (CORS). Will use key directly.', null);
  }
}

function setApiStatus(msg, ok) {
  const el = document.getElementById('api-status');
  el.textContent = msg;
  el.className = 'api-status ' + (ok === true ? 'ok' : ok === false ? 'err' : '');
}

function handleDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('drag');
  const file = e.dataTransfer.files[0];
  if (file) loadFile(file);
}

function loadFile(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => parseCSV(e.target.result);
  reader.readAsText(file);
}

function parseCSV(text) {
  const lines = text.trim().split('\n').map(l => l.trim()).filter(Boolean);
  if (!lines.length) return alert('Empty CSV file');
  
  let startIdx = 0;
  const first = lines[0].toLowerCase();
  if (first.includes('centre') || first.includes('center') || first.includes('name') || first.includes('lat')) {
    startIdx = 1;
  }
  
  csvData = [];
  for (let i = startIdx; i < lines.length; i++) {
    const cols = parseCSVLine(lines[i]);
    if (cols.length < 6) continue;
    csvData.push({
      centreName: cols[0].trim(),
      centreLat: parseFloat(cols[1]),
      centreLng: parseFloat(cols[2]),
      pincode: cols[3].trim(),
      pinLat: parseFloat(cols[4]),
      pinLng: parseFloat(cols[5]),
      status: 'pending',
      resultCentres: '',
      resultDistances: ''
    });
  }
  
  if (!csvData.length) return alert('No valid data rows found. Check CSV format.');
  renderInputTable();
  updateCountInfo();
  document.getElementById('data-section').style.display = 'block';
}

function parseCSVLine(line) {
  const result = [];
  let cur = '', inQuote = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') { inQuote = !inQuote; continue; }
    if (c === ',' && !inQuote) { result.push(cur); cur = ''; continue; }
    cur += c;
  }
  result.push(cur);
  return result;
}

function updateCountInfo() {
  const centres = [...new Set(csvData.map(r => r.centreName))].length;
  const pincodes = [...new Set(csvData.map(r => r.pincode))].length;
  document.getElementById('count-info').textContent = `${csvData.length} rows · ${centres} unique centres · ${pincodes} unique pincodes`;
}

function renderInputTable() {
  const wrap = document.getElementById('input-table-wrap');
  const preview = csvData.slice(0, 20);
  wrap.innerHTML = `
    <table>
      <thead><tr>
        <th>#</th><th>Centre Name</th><th>Centre Lat</th><th>Centre Long</th>
        <th>Pincode</th><th>Pin Lat</th><th>Pin Long</th><th>Status</th>
      </tr></thead>
      <tbody>
        ${preview.map((r,i) => `
          <tr id="row-${i}">
            <td style="color:#aaa;font-size:12px;">${i+1}</td>
            <td>${esc(r.centreName)}</td>
            <td style="font-family:monospace;font-size:12px;">${r.centreLat}</td>
            <td style="font-family:monospace;font-size:12px;">${r.centreLng}</td>
            <td class="col-pin">${esc(r.pincode)}</td>
            <td style="font-family:monospace;font-size:12px;">${r.pinLat}</td>
            <td style="font-family:monospace;font-size:12px;">${r.pinLng}</td>
            <td><span class="status-badge badge-pending" id="status-${i}">Pending</span></td>
          </tr>
        `).join('')}
        ${csvData.length > 20 ? `<tr><td colspan="8" style="text-align:center;color:#aaa;padding:12px;font-size:13px;">... and ${csvData.length - 20} more rows</td></tr>` : ''}
      </tbody>
    </table>`;
}

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

async function runMapping() {
  if (isRunning) return;
  const key = getApiKey();
  if (!key) return alert('Please enter your Google Maps API key first.');
  if (!csvData.length) return alert('Please load CSV data first.');
  
  isRunning = true;
  resultsData = [];
  
  document.getElementById('run-btn').disabled = true;
  document.getElementById('run-btn').innerHTML = '<span class="spinner"></span> Running...';
  document.getElementById('progress-wrap').style.display = 'block';
  document.getElementById('log-panel').innerHTML = '';
  
  const radius = getRadius();
  const pincodeMap = {};
  csvData.forEach(r => {
    if (!pincodeMap[r.pincode]) pincodeMap[r.pincode] = { lat: r.pinLat, lng: r.pinLng, centres: [] };
    if (!pincodeMap[r.pincode].centres.find(c => c.name === r.centreName)) {
      pincodeMap[r.pincode].centres.push({ name: r.centreName, lat: r.centreLat, lng: r.centreLng });
    }
  });

  const allCentres = [];
  const centreNameSet = new Set();
  csvData.forEach(r => {
    if (!centreNameSet.has(r.centreName)) {
      centreNameSet.add(r.centreName);
      allCentres.push({ name: r.centreName, lat: r.centreLat, lng: r.centreLng });
    }
  });

  const pincodes = Object.keys(pincodeMap);
  const total = pincodes.length;
  let done = 0;

  log(`Starting mapping: ${total} pincodes × ${allCentres.length} centres`, 'info');
  log(`Radius: ${radius} km`, 'info');

  for (let i = 0; i < pincodes.length; i++) {
    const pin = pincodes[i];
    const pinInfo = pincodeMap[pin];
    
    log(`Processing pincode ${pin} (${i+1}/${total})...`, 'info');
    
    try {
      const origin = `${pinInfo.lat},${pinInfo.lng}`;
      const destChunks = chunkArray(allCentres, 25);
      
      let allDistResults = [];
      for (const chunk of destChunks) {
        const destinations = chunk.map(c => `${c.lat},${c.lng}`).join('|');
        const url = `https://maps.googleapis.com/maps/api/distancematrix/json?origins=${encodeURIComponent(origin)}&destinations=${encodeURIComponent(destinations)}&units=metric&key=${key}`;
        
        const resp = await callDistanceMatrix(url, origin, destinations, key);
        if (resp && resp.rows && resp.rows[0]) {
          const elements = resp.rows[0].elements;
          elements.forEach((el, j) => {
            if (el.status === 'OK') {
              const distKm = el.distance.value / 1000;
              if (distKm <= radius) {
                allDistResults.push({ name: chunk[j].name, distKm: Math.round(distKm * 10) / 10 });
              }
            }
          });
        }
        await sleep(DELAY_MS);
      }
      
      allDistResults.sort((a, b) => a.distKm - b.distKm);
      
      const centreNames = allDistResults.map(r => r.name).join(', ');
      const distances = allDistResults.map(r => r.distKm + ' km').join(', ');
      
      resultsData.push({
        pincode: pin,
        pinLat: pinInfo.lat,
        pinLng: pinInfo.lng,
        centresFound: allDistResults.length,
        centreNames,
        distances,
        details: allDistResults
      });
      
      log(`✓ ${pin}: ${allDistResults.length} centres within ${radius} km`, 'ok');
    } catch(err) {
      log(`✗ ${pin}: ${err.message}`, 'err');
      resultsData.push({
        pincode: pin, pinLat: pinInfo.lat, pinLng: pinInfo.lng,
        centresFound: 0, centreNames: 'ERROR: ' + err.message, distances: '', details: []
      });
    }
    
    done++;
    const pct = Math.round((done / total) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    document.getElementById('progress-label').textContent = `Processing ${pin}...`;
  }
  
  log(`Done! ${resultsData.length} pincodes processed.`, 'ok');
  document.getElementById('progress-label').textContent = 'Complete!';
  
  renderResults();
  switchTab('results');
  document.getElementById('run-btn').disabled = false;
  document.getElementById('run-btn').innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg> Run Again';
  isRunning = false;
}

async function callDistanceMatrix(url, origin, destinations, key) {
  const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
  try {
    const r = await fetch(proxyUrl);
    const d = await r.json();
    return JSON.parse(d.contents);
  } catch {
    const r2 = await fetch(url);
    return await r2.json();
  }
}

function chunkArray(arr, size) {
  const chunks = [];
  for (let i = 0; i < arr.length; i += size) chunks.push(arr.slice(i, i + size));
  return chunks;
}

function renderResults() {
  const total = resultsData.length;
  const withCentres = resultsData.filter(r => r.centresFound > 0).length;
  const avgCentres = total ? Math.round(resultsData.reduce((s,r) => s + r.centresFound, 0) / total * 10) / 10 : 0;
  const maxCentres = Math.max(...resultsData.map(r => r.centresFound));

  document.getElementById('results-stats').style.display = 'grid';
  document.getElementById('results-stats').innerHTML = `
    <div class="stat-card"><div class="stat-val">${total}</div><div class="stat-label">Pincodes processed</div></div>
    <div class="stat-card"><div class="stat-val">${withCentres}</div><div class="stat-label">With centres nearby</div></div>
    <div class="stat-card"><div class="stat-val">${avgCentres}</div><div class="stat-label">Avg centres per pin</div></div>
    <div class="stat-card"><div class="stat-val">${maxCentres}</div><div class="stat-label">Max centres in range</div></div>
  `;

  document.getElementById('download-btn').style.display = 'inline-flex';

  const wrap = document.getElementById('results-table-wrap');
  wrap.innerHTML = `
    <table>
      <thead><tr>
        <th>Pincode</th><th>Pin Lat</th><th>Pin Long</th>
        <th>Centres Found</th><th>Centre Names</th><th>Distances</th>
      </tr></thead>
      <tbody>
        ${resultsData.map(r => `
          <tr>
            <td class="col-pin">${esc(r.pincode)}</td>
            <td style="font-family:monospace;font-size:12px;">${r.pinLat}</td>
            <td style="font-family:monospace;font-size:12px;">${r.pinLng}</td>
            <td><span class="status-badge ${r.centresFound > 0 ? 'badge-done' : 'badge-error'}">${r.centresFound}</span></td>
            <td class="col-result">
              ${r.details.length ? r.details.map(d => `<span class="centre-chip">${esc(d.name)}</span>`).join('') : '<span style="color:#aaa;font-size:12px;">None within range</span>'}
            </td>
            <td>
              ${r.details.length ? r.details.map(d => `<span class="dist-chip">${d.distKm} km</span>`).join('') : ''}
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>`;
}

function downloadResults() {
  if (!resultsData.length) return;
  const rows = [['Pincode', 'Pin Lat', 'Pin Long', 'Centres Found', 'Centre Names (comma separated)', 'Distances (comma separated)']];
  resultsData.forEach(r => {
    rows.push([r.pincode, r.pinLat, r.pinLng, r.centresFound, `"${r.centreNames}"`, `"${r.distances}"`]);
  });
  downloadCSV(rows, 'pincode_mapping_results.csv');
}

